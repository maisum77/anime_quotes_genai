# Anime Quote Generator - FastAPI Backend Configuration
# Copy this file to .env and update values for your environment.

# ── Application ──────────────────────────────────────
ANIME_QUOTE_APP_NAME="Anime Quote Generator API"
ANIME_QUOTE_APP_VERSION="1.0.0"
ANIME_QUOTE_DEBUG=false
ANIME_QUOTE_ENVIRONMENT=dev
ANIME_QUOTE_API_V1_PREFIX=/api/v1

# ── Server ───────────────────────────────────────────
ANIME_QUOTE_HOST=0.0.0.0
ANIME_QUOTE_PORT=8000
ANIME_QUOTE_RELOAD=false

# ── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed origins
ANIME_QUOTE_CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# ── JWT Authentication ──────────────────────────────
# IMPORTANT: Change this to a strong random key in production!
ANIME_QUOTE_JWT_SECRET_KEY=change-me-in-production-use-a-strong-random-key
ANIME_QUOTE_JWT_ALGORITHM=HS256
ANIME_QUOTE_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
ANIME_QUOTE_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── API Key Authentication ──────────────────────────
ANIME_QUOTE_VALID_API_KEYS=["dev-api-key-001"]

# ── AWS API Gateway ─────────────────────────────────
# Leave empty to use fallback/simulation mode
ANIME_QUOTE_API_GATEWAY_URL=
ANIME_QUOTE_API_GATEWAY_STAGE=dev
ANIME_QUOTE_API_GATEWAY_TIMEOUT=30

# ── AWS Resources ───────────────────────────────────
ANIME_QUOTE_AWS_REGION=us-east-1
# Prefer IAM roles over static credentials
ANIME_QUOTE_AWS_ACCESS_KEY_ID=
ANIME_QUOTE_AWS_SECRET_ACCESS_KEY=

ANIME_QUOTE_S3_BUCKET_NAME=
ANIME_QUOTE_SQS_GENERATION_QUEUE_URL=
ANIME_QUOTE_SQS_POSTPROCESSING_QUEUE_URL=
ANIME_QUOTE_DYNAMODB_JOBS_TABLE=GenerationJobs
ANIME_QUOTE_DYNAMODB_HISTORY_TABLE=UserHistory
ANIME_QUOTE_DYNAMODB_METRICS_TABLE=SystemMetrics
ANIME_QUOTE_SNS_GENERATION_COMPLETE_TOPIC=
ANIME_QUOTE_SNS_GENERATION_FAILED_TOPIC=

# ── WebSocket ────────────────────────────────────────
ANIME_QUOTE_WS_HEARTBEAT_INTERVAL=30
ANIME_QUOTE_WS_MAX_CONNECTIONS=100

# ── Rate Limiting ────────────────────────────────────
ANIME_QUOTE_RATE_LIMIT_PER_MINUTE=60
ANIME_QUOTE_RATE_LIMIT_BURST=10

# ── Redis (optional) ────────────────────────────────
ANIME_QUOTE_REDIS_URL=

# ── Logging ──────────────────────────────────────────
ANIME_QUOTE_LOG_LEVEL=INFO
